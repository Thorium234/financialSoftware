# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — required by the API server and db push
DATABASE_URL=postgresql://user:password@localhost:5432/kenyan_bursar

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080

# Session signing secret (used if auth middleware is added)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Override the default frontend port (default: 5173)
# PORT=5173

# Override the API proxy target if the server runs on a different host/port
# API_URL=http://localhost:8080
